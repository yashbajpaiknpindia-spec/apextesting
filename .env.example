# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/blackapex"

# ─── Admin Authentication ──────────────────────────────────────────────────────
# Strong secret for JWT signing — change this in production!
JWT_SECRET="your-very-long-random-secret-here"

# Admin account credentials (used by: npm run db:seed)
ADMIN_EMAIL="admin@theblackapexconsultancy.com"
ADMIN_PASSWORD="changeme123"

# ─── App ───────────────────────────────────────────────────────────────────────
# Port for the Express server (default: 3000)
PORT=3000

# NODE_ENV: development | production
NODE_ENV="development"

# ─── Gemini AI (optional, existing) ───────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"

# ─── App URL (for SEO metadataBase) ──────────────────────────────────────────
APP_URL="https://theblackapexconsultancy.com"
